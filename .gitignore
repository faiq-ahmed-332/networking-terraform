# ── Terraform state ───────────────────────────────────────────────
# NEVER commit state files — they contain sensitive data (IPs, IDs, secrets)
*.tfstate
*.tfstate.*
*.tfstate.backup

# ── Terraform working directory ───────────────────────────────────
# generated by terraform init — no need to commit, rebuilt on init
.terraform/
.terraform.lock.hcl

# ── Terraform plan files ──────────────────────────────────────────
# binary plan output from terraform plan -out=tfplan
tfplan
*.tfplan

# ── Variable files with real values ───────────────────────────────
# tfvars can contain secrets (keys, passwords, IPs) — keep out of git
*.tfvars
*.tfvars.json

# Exception — commit the example file so others know what vars are needed
!terraform.tfvars.example

# ── Sensitive files ───────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
secrets.txt
.env

# ── CDK (if you add it later) ─────────────────────────────────────
cdk.out/
node_modules/
__pycache__/
*.pyc
.venv/

# ── OS files ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo